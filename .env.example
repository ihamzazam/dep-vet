# DepVet — AI explanation layer (OPTIONAL, provider-agnostic, fails open)
#
# Detection is deterministic (OSV + npm + typosquat + scoring) and works with
# NONE of these set. When all three are set, the AI adds calm, plain-English
# prioritization on top of the real findings. Any error/timeout/missing config
# falls back to the deterministic report — the AI never blocks.
#
# Set all three, then redeploy. Use any OpenAI-compatible provider:

AI_API_KEY=
AI_BASE_URL=
AI_MODEL=

# ── Copy ONE preset into the three vars above (verify current model names) ──
#
# Google Gemini — free tier, no credit card (https://aistudio.google.com):
#   AI_API_KEY=<your Google AI Studio key>
#   AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
#   AI_MODEL=gemini-2.0-flash
#
# Groq — free tier, very fast (https://console.groq.com):
#   AI_API_KEY=<your Groq key>
#   AI_BASE_URL=https://api.groq.com/openai/v1
#   AI_MODEL=llama-3.3-70b-versatile
#
# Anthropic — paid / trial credit, via its OpenAI-compatible endpoint:
#   AI_API_KEY=<your Anthropic key>
#   AI_BASE_URL=https://api.anthropic.com/v1/
#   AI_MODEL=claude-sonnet-4-6
